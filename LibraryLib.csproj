<Project Sdk="Godot.NET.Sdk/4.5.1">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <OutputType>Library</OutputType>
    <AssemblyName>LibraryOfRuinaLib</AssemblyName>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <RemoveUnnecessaryUsings>true</RemoveUnnecessaryUsings>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="sts2">
      <HintPath>libs\sts2.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="0Harmony">
      <HintPath>libs\0Harmony.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="GodotSharp">
      <HintPath>libs\GodotSharp.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="LibraryOfRuinaLib\localization\eng\powers.json" LogicalName="LibraryOfRuinaLib.Localization.eng.powers.json" />
    <EmbeddedResource Include="LibraryOfRuinaLib\localization\zhs\powers.json" LogicalName="LibraryOfRuinaLib.Localization.zhs.powers.json" />
  </ItemGroup>

  <Target Name="CopyToMods" AfterTargets="Build">
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll" DestinationFolder="..\mods\LibraryOfRuinaLib\" />
  </Target>
</Project>
